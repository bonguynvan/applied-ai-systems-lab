# Copy to .env.local and fill in values.
# At least one AI provider key is required. DATABASE_URL is required for analytics/feedback.

# Database (required – Neon, Supabase, or any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# AI providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: Redis for production (rate limit, cache, daily budget across instances)
# Without these, app uses in-memory store (fine for single instance).
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
